#!/usr/bin/env python3
# vim: set ts=8 sts=4 et sw=4 tw=99:
#
# Converts an Excel (.xlsx) file to CSV with two transformations:
#   1. Numeric strings using commas as decimal separators are converted to use decimal points.
#   2. Numeric values with strikethrough formatting are negated.
#
# Usage: excel-to-csv <input.xlsx> <output.csv>

import csv
import sys

try:
    import openpyxl
except ImportError:
    print("Error: openpyxl is required. Install it with: pip install openpyxl", file=sys.stderr)
    sys.exit(1)


def convert_sheet(ws):
    rows = []
    for row in ws.iter_rows():
        out_row = []
        for cell in row:
            val = cell.value
            strike = bool(cell.font and cell.font.strike)

            if isinstance(val, str):
                replaced = val.replace(',', '.')
                try:
                    float(replaced)
                    if strike and not replaced.startswith('-'):
                        val = '-' + replaced
                    else:
                        val = replaced
                except ValueError:
                    pass
            elif isinstance(val, (int, float)) and strike:
                val = -val

            out_row.append('' if val is None else val)
        rows.append(out_row)
    return rows


def convert(input_path, output_path):
    wb = openpyxl.load_workbook(input_path, data_only=True)
    sheets = wb.worksheets

    if len(sheets) == 1:
        rows = convert_sheet(sheets[0])
        with open(output_path, 'w', newline='', encoding='utf-8') as f:
            csv.writer(f).writerows(rows)
    else:
        base, ext = output_path.rsplit('.', 1) if '.' in output_path else (output_path, '')
        suffix = f'.{ext}' if ext else ''
        for i, ws in enumerate(sheets):
            rows = convert_sheet(ws)
            path = f'{base}{i}{suffix}'
            with open(path, 'w', newline='', encoding='utf-8') as f:
                csv.writer(f).writerows(rows)


if __name__ == '__main__':
    if len(sys.argv) != 3:
        print(f"Usage: {sys.argv[0]} <input.xlsx> <output.csv>", file=sys.stderr)
        sys.exit(1)
    convert(sys.argv[1], sys.argv[2])
